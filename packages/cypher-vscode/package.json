      {
        "command": "cypher-cli.new.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
