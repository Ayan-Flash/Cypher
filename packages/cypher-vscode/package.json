        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "sideBarFocus && cypher-cli.new.sidebarVisible || activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel' || activeWebviewPanelId == 'cypher-cli.new.TabPanel'"
      },
      {
        "command": "cypher-cli.new.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "sideBarFocus && cypher-cli.new.sidebarVisible || activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel' || activeWebviewPanelId == 'cypher-cli.new.TabPanel'"
      },
      {
        "command": "cypher-cli.new.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && cypher-cli.new.autocomplete.hasSuggestions"
      },
      {
        "command": "cypher-cli.new.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && cypher.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "cypher-cli.new.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && cypher.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      },
      {
        "command": "cypher-cli.new.autocomplete.nextEdit.acceptOrJump",
        "key": "tab",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && !suggestWidgetVisible && cypher-cli.nextEdit.hasPendingSuggestion"
      },
      {
        "command": "cypher-cli.new.autocomplete.nextEdit.dismiss",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && cypher-cli.nextEdit.hasPendingSuggestion"
      }
    ],
