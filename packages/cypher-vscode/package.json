    "submenus": [
      {
        "id": "cypher-cli.new.editorContextMenu",
        "label": "Cypher CLI"
      },
      {
        "id": "cypher-cli.new.terminalContextMenu",
        "label": "Cypher CLI"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cypher-cli.new.sidebarTitle.plusButtonClicked",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.historyButtonClicked",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.agentManagerOpen",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.cypherClawOpen",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.marketplaceButtonClicked",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.profileButtonClicked",
          "when": "false"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.settingsButtonClicked",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "cypher-cli.new.sidebarTitle.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.cypherClawOpen",
          "group": "navigation@3",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.marketplaceButtonClicked",
          "group": "navigation@4",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == cypher-cli.SidebarProvider"
        },
        {
          "command": "cypher-cli.new.sidebarTitle.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == cypher-cli.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "cypher-cli.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "cypher-cli.new.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "cypher-cli.new.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "cypher-cli.new.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == cypher-cli.new.TabPanel"
        },
        {
          "command": "cypher-cli.new.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == cypher-cli.new.TabPanel"
        },
        {
          "command": "cypher-cli.new.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == cypher-cli.new.TabPanel"
        },
        {
          "command": "cypher-cli.new.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == cypher-cli.new.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "cypher-cli.new.editorContextMenu",
          "group": "1_cypher"
        }
      ],
      "cypher-cli.new.editorContextMenu": [
        {
          "command": "cypher-cli.new.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "cypher-cli.new.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "cypher-cli.new.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "cypher-cli.new.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "cypher-cli.new.terminalContextMenu",
          "group": "2_cypher"
        }
      ],
      "cypher-cli.new.terminalContextMenu": [
        {
          "command": "cypher-cli.new.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "cypher-cli.new.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "cypher-cli.new.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cypher-cli.new.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "cypher-cli.new.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "cypher-cli.new.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "cypher-cli.new.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "cypher-cli.new.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "cypher-cli.new.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel' && !terminalFocus"
      },
      {
        "command": "cypher-cli.new.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "cypher-cli.new.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
      },
      {
        "command": "cypher-cli.new.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'cypher-cli.new.AgentManagerPanel'"
